# ─── Cypress Base URLs ───────────────────────────────────────────────
CYPRESS_BASE_URL=https://your-app-base-url.example.com
CYPRESS_EAP_HOME_URL=https://your-eap-home-url.example.com

# ─── Application URLs (used for NTLM auth targets) ──────────────────
URL_MAIN=https://your-main-url.example.com
URL_EPI_TEST=https://your-epi-test-url.example.com
URL_DEV=https://your-dev-url.example.com
URL_TEST=https://your-test-url.example.com
URL_ANALYTICS=https://your-analytics-url.example.com
URL_INSIDE=https://your-inside-url.example.com

# ─── User Credentials ───────────────────────────────────────────────
LPP_QA_USERNAME=your_qa_username
CYPRESS_LPP_QA_PASSWORD=your_qa_password
CYPRESS_EAP_TESTING_VIEWER_PASSWORD=your_viewer_password
CYPRESS_EAP_TESTING_SHOP_PASSWORD=your_shop_password

# ─── PINs ────────────────────────────────────────────────────────────
CYPRESS_CHECKER_A_PIN=0000
CYPRESS_PRODUCTION_COORDINATOR_PIN=0000

# ─── Cypress Cloud ──────────────────────────────────────────────────
CYPRESS_RECORD_KEY=your_record_key

# ─── K6 Performance Test ────────────────────────────────────────────
K6_API_URL=https://your-api-url.example.com/api/endpoint
